rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Validation
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'streak']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.streak is number &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 128)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 512));
    }

    // Diary Entry Validation
    function isValidEntry(data) {
      return data.keys().hasAll(['content', 'userId', 'mood', 'moodIntensity', 'createdAt', 'updatedAt', 'moodColor']) &&
             data.userId == request.auth.uid &&
             data.content is string && data.content.size() <= 10000 &&
             data.mood in ['happy', 'sad', 'anxious', 'angry', 'neutral'] &&
             data.moodIntensity is number && data.moodIntensity >= 1 && data.moodIntensity <= 10 &&
             data.moodColor is string && data.moodColor.matches('^#[A-Fa-f0-9]{6}$') &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['streak', 'lastEntryDate', 'displayName', 'photoURL']);
      
      match /entries/{entryId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidEntry(incoming());
        allow update: if isOwner(userId) && (
          // Allow full update if valid, or specific fields
          (isValidEntry(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'mood', 'moodIntensity', 'tags', 'suggestedTag', 'aiResponse', 'moodColor', 'updatedAt']))
        );
        allow delete: if isOwner(userId);
      }
    }
  }
}
